rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }
    
    // We mandate verified emails for extra security
    function isVerifiedOwner(userId) {
      return isOwner(userId) && request.auth.token.email_verified == true;
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function isValidId(id) {
      return id is string && id.size() > 0 && id.size() <= 128; // Temporarily removed regex string matching to avoid any Google auth uid issues
    }

    function isValidUserCreate(data) {
      return data.keys().hasAll(["email", "createdAt"])
        && data.keys().size() <= 3
        && data.email is string
        && data.email.size() <= 200
        && data.createdAt == request.time
        && data.get("displayName", "") is string
        && data.get("displayName", "").size() <= 100;
    }

    function isValidUserUpdate(data) {
      return data.get("displayName", "") is string
        && data.get("displayName", "").size() <= 100;
      // email and createdAt cannot change
    }

    match /test/connection {
      allow read: if true;
    }

    match /stories/{storyId} {
      allow read: if true;
      allow write: if false; 
    }

    match /users/{userId} {
      allow get: if isOwner(userId);
      allow list: if false; // Users cannot list all basic users
      allow create: if isOwner(userId) && isValidUserCreate(incoming());
      allow update: if isOwner(userId) && isValidUserUpdate(incoming()) && incoming().email == existing().email && incoming().createdAt == existing().createdAt && incoming().diff(existing()).affectedKeys().hasOnly(['displayName']);
      allow delete: if false; // Disallow user deletion directly from client for now

      match /library/{libraryId} {
        allow get: if isOwner(userId) && isValidId(libraryId);
        allow list: if isOwner(userId);
        
        function isValidLibraryItemCreate(data) {
          return data.keys().hasAll(["storyId", "status", "addedAt"])
            && data.keys().size() == 3
            && data.storyId is string
            && data.storyId.size() <= 128
            && data.status in ["READING", "BOOKMARKED", "COMPLETED", "DROPPED"]
            && data.addedAt == request.time;
        }

        function isValidLibraryItemUpdate(data) {
          return data.status in ["READING", "BOOKMARKED", "COMPLETED", "DROPPED"];
        }

        allow create: if isOwner(userId) && isValidId(libraryId) && isValidLibraryItemCreate(incoming()) && exists(/databases/$(database)/documents/users/$(userId));
        allow update: if isOwner(userId) && isValidId(libraryId) && isValidLibraryItemUpdate(incoming()) && incoming().storyId == existing().storyId && incoming().addedAt == existing().addedAt && incoming().diff(existing()).affectedKeys().hasOnly(['status']);
        allow delete: if isOwner(userId) && isValidId(libraryId);
      }

      match /readingHistory/{historyId} {
        allow get: if isOwner(userId) && isValidId(historyId);
        allow list: if isOwner(userId);

        function isValidHistoryItem(data) {
          return data.keys().hasAll(["storyId", "platformId", "timestamp"])
            && data.keys().size() == 3
            && data.storyId is string
            && data.storyId.size() <= 128
            && data.platformId is string
            && data.platformId.size() <= 128
            && data.timestamp == request.time;
        }

        allow create: if isOwner(userId) && isValidId(historyId) && isValidHistoryItem(incoming()) && exists(/databases/$(database)/documents/users/$(userId));
        allow update: if isOwner(userId) && isValidId(historyId) && isValidHistoryItem(incoming()) && incoming().storyId == existing().storyId && incoming().diff(existing()).affectedKeys().hasOnly(['platformId', 'timestamp']);
        allow delete: if isOwner(userId) && isValidId(historyId);
      }
    }
  }
}
